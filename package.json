{
  "name": "vesta-ui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@11.15.0",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "biome check .",
    "format": "biome check --write .",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "husky"
  },
  "lint-staged": {
    "*": "biome check --write --no-errors-on-unmatched"
  },
